# =============================================================================
# MatchHire Development Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your environment
# This file is for development use only

# =============================================================================
# Django Configuration
# =============================================================================
SECRET_KEY=django-insecure-dev-key-for-local-development-only-change-in-production
DEBUG=True
DJANGO_SETTINGS_MODULE=matchhire_backend.settings.dev
ENVIRONMENT=development

# =============================================================================
# Database Configuration (PostgreSQL - Docker)
# =============================================================================
DB_NAME=matchhire
DB_USER=matchhire
DB_PASSWORD=matchhire
DB_HOST=db
DB_PORT=5432

# =============================================================================
# Redis Configuration (Docker)
# =============================================================================
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379

# =============================================================================
# Celery Configuration
# =============================================================================
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# =============================================================================
# CORS Configuration
# =============================================================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# =============================================================================
# Sentry Configuration (Optional - for error monitoring)
# =============================================================================
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
# SENTRY_RELEASE=1.0.0
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_ERROR_SAMPLE_RATE=1.0
# SENTRY_SERVER_NAME=matchhire-backend
